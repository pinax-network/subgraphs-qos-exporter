# Copy to .env for local testing (`.env` is gitignored). Bun auto-loads .env.
# RPC_URL is the only required var — a full JSON-RPC endpoint for the chain the DataEdge
# contract lives on (Gnosis). Everything else has sensible defaults (see README).
RPC_URL=https://gnosis.rpc.pinax.network/v1/<PINAX_API_KEY>/
# IPFS_URL=https://ipfs.thegraph.com     # or your own kubo: http://ipfs.subgraphs:5001
# QOS_CONTRACTS=0x5b4293b4c0f36cb5d4448950830bc777759b6c4f
# QOS_TOPIC=gateway_query_result_qos_5_minutes_prod_v3
# SCAN_BLOCKS=180
# REFRESH_SECONDS=300
# PORT=9090
# NAME_QUERY_URL=            # optional network-subgraph GraphQL endpoint → adds subgraph `name` label
# OUR_INDEXER=0x3717cef8020bddee7a18f4efb2bfa88fefdcb1bc   # drives graph_qos_our_* rank/share
